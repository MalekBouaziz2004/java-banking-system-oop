<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="ui.AccountViewController">

    <!-- OBEN: Accountname + Kontostand + Back-Button -->
    <top>
        <HBox spacing="20" style="-fx-padding: 10;">
            <Button fx:id="backButton" text="Zurück" />
            <Label fx:id="accountNameLabel" style="-fx-font-size: 18px;"/>
            <Label fx:id="balanceLabel" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
        </HBox>
    </top>

    <!-- CENTER: Liste der Transaktionen -->
    <center>
        <ListView fx:id="transactionListView" />
    </center>

    <!-- UNTEN: Sortieroptionen und "Neue Transaktion" Button -->
    <bottom>
        <HBox spacing="10" style="-fx-padding: 10;">
            <Button fx:id="sortAscButton" text="Aufsteigend" />
            <Button fx:id="sortDescButton" text="Absteigend" />
            <Button fx:id="filterPosButton" text="Nur positive" />
            <Button fx:id="filterNegButton" text="Nur negative" />

            <Pane HBox.hgrow="ALWAYS" />

            <Button fx:id="newTransactionButton" text="Neue Transaktion" />
        </HBox>
    </bottom>

</BorderPane>
